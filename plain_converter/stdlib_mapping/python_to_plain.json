    "str_methods": {
        "upper": {
            "plain_name": "upper",
            "call_style": "function_from_method",
            "arg_transform": "object_becomes_first_arg",
            "notes": "s.upper() -> upper(s)"
        },
        "lower": {
            "plain_name": "lower",
            "call_style": "function_from_method",
            "arg_transform": "object_becomes_first_arg",
            "notes": "s.lower() -> lower(s)"
        },
        "strip": {
            "plain_name": "trim",
            "call_style": "function_from_method",
            "arg_transform": "object_becomes_first_arg",
            "notes": "s.strip() -> trim(s)"
        },
        "split": {
            "plain_name": "split",
            "call_style": "function_from_method",
            "arg_transform": "object_becomes_first_arg",
            "notes": "s.split(d) -> split(s, d)"
        },
        "join": {
            "plain_name": "join",
            "call_style": "function_from_method",
            "arg_transform": "swap_object_and_first_arg",
            "notes": "sep.join(lst) -> join(lst, sep) - args reversed"
        },
        "replace": {
            "plain_name": "replace",
            "call_style": "function_from_method",
            "arg_transform": "object_becomes_first_arg",
            "notes": "s.replace(old, new) -> replace(s, old, new)"
        },
        "startswith": {
            "plain_name": "starts_with",
            "call_style": "function_from_method",
            "arg_transform": "object_becomes_first_arg",
            "notes": "s.startswith(p) -> starts_with(s, p)"
        },
        "endswith": {
            "plain_name": "ends_with",
            "call_style": "function_from_method",
            "arg_transform": "object_becomes_first_arg",
            "notes": "s.endswith(s) -> ends_with(s, s)"
        }
    },

    "list_methods": {
