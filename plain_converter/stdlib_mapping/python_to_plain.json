            "notes": "Same name"
        },
        "max": {
            "plain_name": "max",
            "call_style": "function",
            "notes": "Same name"
        },
        "chr": {
            "plain_name": "chr",
            "call_style": "function",
            "notes": "Same name"
        },
        "ord": {
            "plain_name": "ord",
            "call_style": "function",
