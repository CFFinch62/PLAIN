rem: PLAIN Quiz Game - Questions Module
rem: Contains the full bank of 60 quiz questions (20 per level).
rem: Each question is a table with keys:
rem:   question - the question text
rem:   a, b, c, d - the four answer choices
rem:   answer    - the correct choice letter ("a", "b", "c", or "d")
rem:   level     - difficulty level ("beg", "int", or "pro")

task BuildQuestions
    var questions = []

    rem: ============ BEGINNER QUESTIONS ============

    rem: BEG Q1
    var q = {}
    q["question"] = "What keyword displays output to the console in PLAIN?"
    q["a"] = "print"
    q["b"] = "output"
    q["c"] = "display"
    q["d"] = "show"
    q["answer"] = "c"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q2
    q = {}
    q["question"] = "What keyword declares a mutable variable in PLAIN?"
    q["a"] = "set"
    q["b"] = "let"
    q["c"] = "def"
    q["d"] = "var"
    q["answer"] = "d"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q3
    q = {}
    q["question"] = "What keyword declares a constant (fixed value) in PLAIN?"
    q["a"] = "const"
    q["b"] = "fxd"
    q["c"] = "final"
    q["d"] = "fixed"
    q["answer"] = "b"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q4
    q = {}
    q["question"] = "What is the single-line comment syntax in PLAIN?"
    q["a"] = "#"
    q["b"] = "//"
    q["c"] = "rem:"
    q["d"] = "--"
    q["answer"] = "c"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q5
    q = {}
    q["question"] = "What keyword starts a multi-line comment block in PLAIN?"
    q["a"] = "rem:"
    q["b"] = "note:"
    q["c"] = "comment:"
    q["d"] = "block:"
    q["answer"] = "b"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q6
    q = {}
    q["question"] = "How do you get user input in PLAIN?"
    q["a"] = "input()"
    q["b"] = "read()"
    q["c"] = "scan()"
    q["d"] = "get()"
    q["answer"] = "d"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q7
    q = {}
    q["question"] = "What operator concatenates strings in PLAIN?"
    q["a"] = "+"
    q["b"] = "&"
    q["c"] = ".."
    q["d"] = "concat"
    q["answer"] = "b"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q8
    q = {}
    q["question"] = "What is the boolean literal for false in PLAIN?"
    q["a"] = "False"
    q["b"] = "FALSE"
    q["c"] = "false"
    q["d"] = "no"
    q["answer"] = "c"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q9
    q = {}
    q["question"] = "What keyword starts conditional logic in PLAIN?"
    q["a"] = "when"
    q["b"] = "check"
    q["c"] = "if"
    q["d"] = "test"
    q["answer"] = "c"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q10
    q = {}
    q["question"] = "What keyword starts the else branch in PLAIN?"
    q["a"] = "otherwise"
    q["b"] = "elif"
    q["c"] = "or"
    q["d"] = "else"
    q["answer"] = "d"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q11
    q = {}
    q["question"] = "What syntax creates an empty list in PLAIN?"
    q["a"] = "()"
    q["b"] = "{}"
    q["c"] = "[]"
    q["d"] = "list()"
    q["answer"] = "c"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q12
    q = {}
