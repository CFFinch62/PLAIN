    q["a"] = "[]"
    q["b"] = "()"
    q["c"] = "table()"
    q["d"] = "{}"
    q["answer"] = "d"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q13
    q = {}
    q["question"] = "What keyword defines a named task (function or procedure) in PLAIN?"
    q["a"] = "def"
    q["b"] = "func"
    q["c"] = "task"
    q["d"] = "sub"
    q["answer"] = "c"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q14
    q = {}
