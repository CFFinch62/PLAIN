    q["b"] = "stop"
    q["c"] = "exit"
    q["d"] = "quit"
    q["answer"] = "c"
    q["level"] = "beg"
    append(questions, q)

    rem: BEG Q17
    q = {}
    q["question"] = "What keyword skips to the next loop iteration in PLAIN?"
    q["a"] = "next"
