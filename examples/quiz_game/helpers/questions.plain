    q["b"] = "task Name using (params)"
    q["c"] = "task Name proc (params)"
    q["d"] = "task Name do (params)"
    q["answer"] = "a"
    q["level"] = "int"
    append(questions, q)

    rem: INT Q4
    q = {}
    q["question"] = "Are task parameters mutable or immutable in PLAIN?"
    q["a"] = "Mutable — can be changed inside the task"
    q["b"] = "Immutable — cannot be changed inside the task"
    q["c"] = "Optional — may or may not be passed"
    q["d"] = "Global — visible outside the task"
