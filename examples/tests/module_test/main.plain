rem: ============================================================
rem: COMPREHENSIVE MODULE & IMPORT TEST
rem: ============================================================
rem: This test verifies all documented import behaviors in PLAIN:
rem:
rem:   1. Task-level imports  (tasks:)   - direct call, no prefix
rem:   2. Module-level imports (modules:) - qualified call with prefix
rem:   3. Assembly-level imports (assemblies:) - full path access
rem:   4. Mixed import styles in one use: block
rem:   5. Root-level modules (no assembly)
rem:   6. Assembly modules (subdirectory)
rem:   7. Multiple assemblies
rem:   8. Module isolation (no cross-contamination)
rem:   9. Multiple tasks from same module
rem:  10. Tasks from different modules in same assembly
rem:
rem: Project Structure:
rem:   module_test/
rem:     main.plain            (this file - entry point)
rem:     helpers.plain          (root-level module)
rem:     mathlib/               (assembly)
rem:       arithmetic.plain     (module)
rem:       geometry.plain       (module)
rem:     textlib/               (assembly)
rem:       formatting.plain     (module)
rem:
rem: Expected: All tests PASS. Any FAIL indicates a discrepancy
rem:           between documentation and implementation.
rem: ============================================================

use:
    assemblies:
        mathlib
        textlib

    modules:
        helpers
        mathlib.geometry
        textlib.formatting

    tasks:
        mathlib.arithmetic.Add
        mathlib.arithmetic.Subtract
        mathlib.arithmetic.Square
        helpers.Greet
        textlib.formatting.Capitalize

rem: ============================================================
rem: Test infrastructure
rem: ============================================================
var intPass = 0
var intFail = 0
var intTotal = 0

task Assert with (strLabel, blnCondition)
    intTotal += 1
    if blnCondition
        intPass += 1
        display("  PASS: " & strLabel)
    else
        intFail += 1
        display("  FAIL: " & strLabel)

task Section with (title)
    display("")
    display("--- " & title & " ---")

rem: ============================================================
rem: MAIN TEST RUNNER
rem: ============================================================
task Main()
    display("============================================================")
    display("  PLAIN Module & Import System - Comprehensive Test")
    display("============================================================")

    rem: --------------------------------------------------------
    rem: TEST 1: Task-level imports - direct call without prefix
    rem: --------------------------------------------------------
    rem: Per docs: "Imported tasks callable directly without prefix"
    rem: We imported: Add, Subtract, Square from mathlib.arithmetic
    rem:             Greet from helpers
    rem:             Capitalize from textlib.formatting
    Section("TEST 1: Task-Level Imports (tasks:)")

    var result1 = Add(10, 5)
    Assert("Add(10, 5) == 15 (direct call, no prefix)", result1 == 15)

    var result2 = Subtract(20, 8)
    Assert("Subtract(20, 8) == 12 (direct call, no prefix)", result2 == 12)

    var result3 = Square(7)
    Assert("Square(7) == 49 (direct call, no prefix)", result3 == 49)

    var result4 = Greet("PLAIN")
    Assert("Greet('PLAIN') works (root module task import)", result4 == "Hello, PLAIN!")

    var result5 = Capitalize("hello")
    Assert("Capitalize('hello') == 'Hello' (assembly task import)", result5 == "Hello")

    rem: --------------------------------------------------------
    rem: TEST 2: Module-level imports - qualified call with prefix
    rem: --------------------------------------------------------
    rem: Per docs: "All tasks in the module become accessible via module.TaskName"
    rem: We imported: helpers, mathlib.geometry, textlib.formatting
    Section("TEST 2: Module-Level Imports (modules:)")

    var result6 = helpers.AddNumbers(3, 4)
    Assert("helpers.AddNumbers(3, 4) == 7 (root module qualified)", result6 == 7)

    var result7 = helpers.GetModuleStatus()
    Assert("helpers.GetModuleStatus() works (root module qualified)", result7 == "helpers module loaded")

    var result8 = mathlib.geometry.CircleArea(1)
    Assert("mathlib.geometry.CircleArea(1) ~ 3.14 (assembly.module qualified)", result8 > 3.14 and result8 < 3.15)

    var result9 = mathlib.geometry.RectangleArea(5, 10)
    Assert("mathlib.geometry.RectangleArea(5, 10) == 50 (assembly.module)", result9 == 50)

    var result10 = mathlib.geometry.TriangleArea(6, 8)
    Assert("mathlib.geometry.TriangleArea(6, 8) == 24 (assembly.module)", result10 == 24.0)

    var result11 = mathlib.geometry.GetPi()
    Assert("mathlib.geometry.GetPi() ~ 3.14159 (module constant access)", result11 > 3.141 and result11 < 3.142)

    var result12 = textlib.formatting.Banner("Test")
    Assert("textlib.formatting.Banner('Test') works (second assembly)", len(result12) > 0)

    var result13 = textlib.formatting.Repeat("ab", 3)
    Assert("textlib.formatting.Repeat('ab', 3) == 'ababab'", result13 == "ababab")

    var result14 = textlib.formatting.PadRight("hi", 5)
    Assert("textlib.formatting.PadRight('hi', 5) has length 5", len(result14) == 5)

    rem: --------------------------------------------------------
    rem: TEST 3: Task import also enables qualified module access
    rem: --------------------------------------------------------
    rem: Per docs: "Automatically makes parent module and assembly available"
    rem: Since we imported mathlib.arithmetic.Add as a task,
    rem: mathlib.arithmetic should be accessible as a module too.
    Section("TEST 3: Task Import Enables Qualified Access")

    var result15 = mathlib.arithmetic.Multiply(6, 7)
    Assert("mathlib.arithmetic.Multiply(6, 7) == 42 (qualified via task import)", result15 == 42)

    var result16 = mathlib.arithmetic.Divide(100, 4)
    Assert("mathlib.arithmetic.Divide(100, 4) == 25 (qualified via task import)", result16 == 25)

    rem: --------------------------------------------------------
    rem: TEST 4: Assembly-level imports
    rem: --------------------------------------------------------
    rem: Per docs: "All modules within the assembly become accessible"
    rem: We imported assemblies: mathlib, textlib
    rem: Note: assemblies just register availability - modules still
    rem: need to be explicitly imported or accessed by full path.
    Section("TEST 4: Assembly-Level Imports (assemblies:)")

    Assert("mathlib assembly registered (geometry accessible)", result8 > 3.14)
    Assert("textlib assembly registered (formatting accessible)", len(result12) > 0)

    rem: --------------------------------------------------------
    rem: TEST 5: Multiple tasks from the same module
    rem: --------------------------------------------------------
    rem: Verifies importing multiple tasks from one module works.
    Section("TEST 5: Multiple Tasks from Same Module")

    var a = Add(100, 200)
    var b = Subtract(100, 200)
    var c = Square(10)
    Assert("Add(100, 200) == 300", a == 300)
    Assert("Subtract(100, 200) == -100", b == -100)
    Assert("Square(10) == 100", c == 100)

    rem: --------------------------------------------------------
    rem: TEST 6: Tasks from different modules
    rem: --------------------------------------------------------
    rem: Verifies no collision between tasks from different modules.
    Section("TEST 6: Cross-Module Task Usage")

    rem: Mix calls from different modules in one expression
    var areaOfSquare = mathlib.geometry.RectangleArea(Square(3), Square(3))
    Assert("Nested: RectangleArea(Square(3), Square(3)) == 81", areaOfSquare == 81)

    var greeting = Greet(Capitalize("world"))
    Assert("Nested: Greet(Capitalize('world')) == 'Hello, World!'", greeting == "Hello, World!")

    rem: --------------------------------------------------------
    rem: TEST 7: Error handling across modules
    rem: --------------------------------------------------------
    rem: Per docs: abort propagates up the call stack until caught
    Section("TEST 7: Error Handling Across Module Boundaries")

    var divResult = 0
    var caughtError = false
    attempt
        divResult = mathlib.arithmetic.Divide(10, 0)
    handle
        caughtError = true

    Assert("Division by zero abort caught from imported module", caughtError)
    Assert("divResult unchanged after caught abort", divResult == 0)

    rem: --------------------------------------------------------
    rem: TEST 8: Module isolation - tasks don't leak
    rem: --------------------------------------------------------
    rem: Per docs: "Module-level variables are NOT global"
    Section("TEST 8: Module Isolation")

    rem: helpers has a var moduleLoaded = true
    rem: It should NOT be directly accessible from main
    rem: Only tasks exported through the module namespace should work
    var canAccessHelperTask = true
    attempt
        var status = helpers.GetModuleStatus()
    handle
        canAccessHelperTask = false

    Assert("Can call helpers.GetModuleStatus()", canAccessHelperTask)

    rem: --------------------------------------------------------
    rem: TEST 9: Return type preservation across modules
    rem: --------------------------------------------------------
    rem: Verify that return values maintain their types across module boundaries
    Section("TEST 9: Return Types Across Modules")

    var intResult = Add(1, 2)
    Assert("Integer return preserved: is_int(Add(1, 2))", is_int(intResult))

    var fltResult = mathlib.geometry.CircleArea(1)
    Assert("Float return preserved: is_float(CircleArea(1))", is_float(fltResult))

    var strResult = Greet("Test")
    Assert("String return preserved: is_string(Greet('Test'))", is_string(strResult))

    var lstExpected = mathlib.geometry.GetPi()
    Assert("Float constant: is_float(GetPi())", is_float(lstExpected))

    rem: --------------------------------------------------------
    rem: TEST 10: Multiple calls to same imported task
    rem: --------------------------------------------------------
    rem: Verify tasks can be called repeatedly without issues
    Section("TEST 10: Repeated Calls")

    var sum = 0
    loop i from 1 to 10
        sum = sum + Add(i, 0)
    Assert("10 repeated calls to Add: sum of 1..10 == 55", sum == 55)

    var allCaps = ""
    var lstWords = ["hello", "world", "plain"]
    loop word in lstWords
        allCaps = allCaps & Capitalize(word) & " "
    Assert("3 repeated calls to Capitalize", starts_with(allCaps, "Hello World Plain"))

    rem: ============================================================
    rem: SUMMARY
    rem: ============================================================
    display("")
    display("============================================================")
    display("  TEST SUMMARY")
    display("============================================================")
    display(v"  Total:  {intTotal}")
    display(v"  Passed: {intPass}")
    display(v"  Failed: {intFail}")
    display("============================================================")

    if intFail == 0
        display("  ALL TESTS PASSED")
    else
        display(v"  WARNING: {intFail} test(s) FAILED")
        display("  Documentation may not match implementation!")

    display("============================================================")
