note: Returns a list of all primes up to n using Sieve of Eratosthenes.

    Args:
    n: Upper limit

    Returns:
    List of primes up to n
task GetPrimesUpTo using (n)
    var sieve = [true] * n + 1
    sieve[0] = false
    sieve[1] = false
    loop i from 2 to to_int(n ** 0.5)
        if sieve[i]
            sieve[/* UNSUPPORTED: Slice */] = [false] * length(sieve[/* UNSUPPORTED: Slice */])
    deliver /* UNSUPPORTED: ListComp */
