rem: HELPERS

task ListMax using (l)
    var max = 0
    loop i from 0 to len(l)-1
		if l[i] > max
      		max = l[i]
	deliver max

task IsValid using (i, j, rows, cols)
    if i < 0 or i >= rows or j >= cols or j < 0
        deliver false
    deliver true
    
rem: Get greatest product of any group of adjacent
rem: numbers in up_right diagonals of a given array
task GrtProdUp using (arr, rows, cols, group)
    var tmp = []
    var topp = []
    var tmpp = []
    var tmpsum = 1
    var topsum = 0
    var botsum = 0

	rem: process top half of diagonals ([0,0] to [0,rows-1])
    loop k from 0 to rows - 1
        append(tmp, arr[k][0])
        var i = k - 1
        var j = 1
        loop IsValid(i, j, rows, cols)
            append(tmp, arr[i][j])
            i -= 1
            j += 1
        if len(tmp) >= group
            loop l from 0 to (len(tmp) - (group - 1)) - 1
                loop m from 0 to group - 1
                    append(tmpp, tmp[m + l])
                    tmpsum *= tmp[m + l]
                if tmpsum > topsum
                    topsum = tmpsum
                    topp = tmpp
                tmpsum = 1
                tmpp = []
        tmp = []
        tmpsum = 1
    display("Max diagonal up right top group:", topp, "Product is:", topsum)
    
	rem: process bottom half of diagonals ([row-1, 1] to [rows-1, cols-1])
    loop k from 1 to cols - 1
        append(tmp, arr[rows - 1][k])
        var i = rows - 2
        var j = k + 1
        loop IsValid(i, j, rows, cols)
            append(tmp, arr[i][j])
            i -= 1
            j += 1
        if len(tmp) >= group
            loop l from 0 to (len(tmp) - (group - 1)) - 1
                loop m from 0 to group - 1
                    append(tmpp, tmp[m + l])
                    tmpsum *= tmp[m + l]
                if tmpsum > botsum
                    botsum = tmpsum
                    topp = tmpp
                tmpsum = 1
                tmpp = []
        tmp = []
        tmpsum = 1
    display("Max diagonal up right bot group:", topp, "Product is:", botsum)
    display()
    if topsum > botsum
        deliver topsum
    else
        deliver botsum
 
rem: Get greatest product of any group of adjacent
rem: numbers in up_left diagonals of a given array       
task GrtProdDn using (arr, rows, cols, group)
    var tmp = []
    var topp = []
    var tmpp = []
    var i = 0
    var j = 0
    var tmpsum = 0
    var topsum = 0
    var botsum = 0
    
	rem: process top half of diagonals ([0, cols-1] to [rows-1, cols-1])
    loop k from 0 to cols - 1
        append(tmp, arr[0][k])
        i += 1
        j = k + 1
        loop IsValid(i, j, rows, cols)
            append(tmp, arr[i][j])
            i += 1
            j += 1
        i = 0
        j = 0
        if len(tmp) >= group
            loop l from 0 to (len(tmp) - (group - 1) - 1)
                loop m from 0 to group - 1
                    append(tmpp, tmp[m + l])
                    tmpsum *= tmp[m + l]
                if tmpsum > topsum
                    topsum = tmpsum
                    topp = tmpp
                tmpsum = 1
                tmpp = []
        tmp = []
        tmpsum = 1
    display("Max diagonal dn right top group:", topp, "Product is:", topsum)
    
	rem: process bottom half of diagonals ([row-1, 1] to [rows-1, cols-2])
    loop k from 1 to rows - 1
        append(tmp, arr[k][0])
        i = k + 1
        j += 1
        loop IsValid(i, j, rows, cols)
            append(tmp, arr[i][j])
            i += 1
            j += 1
        i = 0
        j = 0
        if len(tmp) >= group
            loop l from 0 to (len(tmp) - (group - 1) - 1)
                loop m from 0 to group - 1
                    append(tmpp, tmp[m + l])
                    tmpsum = tmpsum * tmp[m + l]
                if tmpsum > topsum
                    topsum = tmpsum
                    topp = tmpp
                tmpsum = 1
                tmpp = []
        tmp = []
        tmpsum = 1
    display("Max diagonal dn right bot group:", topp, "Product is:", topsum)
    display()

    if topsum > botsum
        deliver topsum
    else
        deliver botsum


task GrtProdRows using (arr, rows, cols, group)
    var tmpp = []
    var topp = []
    var tmpsum = 1
    var maxsum = 0
    loop r from 0 to rows - 1
        loop c from 0 to cols - group - 1 - 1
            loop i from 0 to group - 1
                append(tmpp, arr[r][c + i])
                tmpsum = tmpsum * arr[r][c + i]
                if tmpsum > maxsum
                    maxsum = tmpsum
                    topp = tmpp
            tmpsum = 1
            tmpp = []
    display("Max rows group:", topp, "Product is:", maxsum)
    display()
    deliver maxsum

task GrtProdCols using (arr, rows, cols, group)
    var tmpp = []
    var topp = []
    var tmpsum = 1
    var maxsum = 0
    loop c from 0 to cols - 1
        loop r from 0 to rows - group - 1 - 1
            loop i from 0 to group - 1
                append(tmpp, arr[r + i][c])
                tmpsum = tmpsum * arr[r + i][c]
                if tmpsum > maxsum
                    maxsum = tmpsum
                    topp = tmpp
            tmpsum = 1
            tmpp = []
    display("Max cols group:", topp, "Product is:", maxsum)
    display()
    deliver maxsum

