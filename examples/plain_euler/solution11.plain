display()
var begin = time()
append(products, GrtProdRows(tst, len(tst), len(tst[0]), 4))
append(products, GrtProdCols(tst, len(tst), len(tst[0]), 4))
append(products, GrtProdUp(tst, len(tst), len(tst[0]), 4))
